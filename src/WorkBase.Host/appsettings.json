{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "WorkBase"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=workbase;Username=workbase;Password=workbase"
  },
  "Hangfire": {
    "DashboardEnabled": true
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/workbase",
    "Audience": "workbase-api",
    "RequireHttpsMetadata": false,
    "Realm": "workbase",
    "MultiRealmEnabled": false,
    "Admin": {
      "ClientId": "admin-cli",
      "Username": "",
      "Password": ""
    }
  },
  "Storage": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "workbase",
    "UseSSL": false
  },
  "Stripe": {
    "WebhookSecret": ""
  },
  "Hub": {
    "Enabled": false,
    "BaseUrl": "",
    "InstanceId": "",
    "ClientId": "workbase",
    "ClientSecret": "",
    "WebhookSecret": "",
    "EmployeeAccessSyncEnabled": false,
    "UserAccessCheckEnabled": false,
    "TenantId": "00000000-0000-0000-0000-000000000001",
    "Issuer": "",
    "FrontendUrl": ""
  },
  "Ecosystem": {
    "Enabled": false,
    "BaseUrl": "http://localhost:4200",
    "Secret": "",
    "TenantId": "00000000-0000-0000-0000-000000000001",
    "HubOrgId": "",
    "TimeZone": "Europe/Warsaw"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5174"
    ]
  },
  "Integration": {
    "EncryptionKey": "",
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common"
    },
    "Slack": {
      "ClientId": "",
      "ClientSecret": ""
    }
  }
}

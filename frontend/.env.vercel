# Vercel Environment Variables
# Wgraj te wartości w Vercel → Settings → Environment Variables
# (każdy klucz = nazwa zmiennej, wartość = to co po '=')

VITE_API_URL=https://workbase-api.onrender.com
VITE_KEYCLOAK_AUTHORITY=https://workbase-auth.onrender.com/realms/workbase
VITE_KEYCLOAK_CLIENT_ID=workbase-web
VITE_REDIRECT_URI=https://work-base-roan.vercel.app/auth/callback
VITE_POST_LOGOUT_REDIRECT_URI=https://work-base-roan.vercel.app

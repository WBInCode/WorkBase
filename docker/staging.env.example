# =============================================================================
# WorkBase — Staging Environment Variables
# Copy to .env on the staging server at /opt/workbase/.env
# =============================================================================

# --- PostgreSQL ---
DATABASE_NAME=workbase
DATABASE_USER=workbase
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Keycloak ---
KEYCLOAK_REALM=workbase
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
KEYCLOAK_HOSTNAME=auth.staging.workbase.example.com

# --- MinIO ---
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=workbase

# --- Container Images ---
API_IMAGE=ghcr.io/wbincode/workbase/workbase-api:latest
FRONTEND_IMAGE=ghcr.io/wbincode/workbase/workbase-frontend:latest

# --- Application ---
FRONTEND_URL=https://app.staging.workbase.example.com
INTEGRATION_ENCRYPTION_KEY=

# --- WB Platform / HUB ---
# Wartości *_SECRET muszą odpowiadać rekordom SsoClient/Webhook w HUB.
# Wszystkie trzy flagi włączyć dopiero po skoordynowanym rolloucie z docs/06.
Hub__Enabled=false
Hub__BaseUrl=https://hub.staging.example.com
Hub__InstanceId=CHANGE_ME_WORKBASE_PRODUCT_INSTANCE_ID
Hub__ClientId=workbase
Hub__ClientSecret=CHANGE_ME_PRODUCT_CLIENT_SECRET
Hub__WebhookSecret=CHANGE_ME_WEBHOOK_HMAC_SECRET
Hub__TenantId=00000000-0000-0000-0000-000000000001
Hub__Issuer=https://hub.staging.example.com
Hub__FrontendUrl=https://app.staging.workbase.example.com
Hub__EmployeeAccessSyncEnabled=false
Hub__UserAccessCheckEnabled=false

# --- Stripe (billing webhook signature verification) ---
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET

# --- Backup ---
BACKUP_RETENTION_DAYS=30

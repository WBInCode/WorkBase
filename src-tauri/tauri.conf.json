{
  "$schema": "https://raw.githubusercontent.com/nickheal/tauri-v2-schemas/refs/heads/main/tauri.conf.schema.json",
  "productName": "WorkBase Desktop",
  "version": "0.1.0",
  "identifier": "pl.workbase.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "title": "WorkBase",
    "windows": [
      {
        "title": "WorkBase",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://*.workbase.local; img-src 'self' data: blob:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "WorkBase",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pl-PL"
      }
    }
  },
  "plugins": {
    "notification": {
      "enabled": true
    }
  }
}

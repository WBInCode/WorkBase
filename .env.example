# =============================================================================
# WorkBase — Environment Variables
# Skopiuj do .env i uzupełnij wartości
# =============================================================================

# --- PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=workbase
DATABASE_USER=workbase
DATABASE_PASSWORD=workbase

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=workbase
KEYCLOAK_CLIENT_ID=workbase-web
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# --- MinIO (S3-compatible file storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workbase
MINIO_USE_SSL=false

# --- Seq (structured logging) ---
SEQ_URL=http://localhost:5341

# --- Hangfire ---
HANGFIRE_DASHBOARD_ENABLED=true

# --- Application ---
APP_URL=https://localhost:5001
FRONTEND_URL=http://localhost:5173
ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# WorkBase — Environment Variables
# Skopiuj do .env i uzupełnij wartości
# =============================================================================

# --- PostgreSQL ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=workbase
DATABASE_USER=workbase
DATABASE_PASSWORD=workbase

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=workbase
KEYCLOAK_CLIENT_ID=workbase-web
KEYCLOAK_CLIENT_SECRET=workbase-api-dev-secret
KEYCLOAK_API_CLIENT_ID=workbase-api
KEYCLOAK_API_CLIENT_SECRET=workbase-api-dev-secret

# --- MinIO (S3-compatible file storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=workbase
MINIO_USE_SSL=false

# --- Seq (structured logging) ---
SEQ_URL=http://localhost:5341

# --- Hangfire ---
HANGFIRE_DASHBOARD_ENABLED=true

# --- WB Ecosystem: WorkBase -> Rytm (optional) ---
Ecosystem__Enabled=false
Ecosystem__BaseUrl=http://localhost:4200
Ecosystem__Secret=
Ecosystem__TenantId=00000000-0000-0000-0000-000000000001
Ecosystem__HubOrgId=
Ecosystem__TimeZone=Europe/Warsaw

# --- Stripe (billing webhook) ---
# Wymagane, aby endpoint /api/billing/webhook przyjmował zdarzenia (fail-closed jeśli puste)
STRIPE_WEBHOOK_SECRET=

# --- Application ---
APP_URL=https://localhost:5001
FRONTEND_URL=http://localhost:5173
ASPNETCORE_ENVIRONMENT=Development
